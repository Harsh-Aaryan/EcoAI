# Auth0 - Replace with your Auth0 credentials
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id

# MongoDB - Used by backend (FastAPI)
VITE_API_URL=http://localhost:8000

# WattTime API
VITE_WATTTIME_USER=your-watttime-user
VITE_WATTTIME_PASS=your-watttime-pass

# EIA API
VITE_EIA_API_KEY=your-eia-key

# Groq API
VITE_GROQ_API_KEY=your-groq-key
